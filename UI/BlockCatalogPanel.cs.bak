        public BlockCatalogPanel()
        {
            _preferences = PreferencesManager.Instance.Load();
            _currentStyle = LoadStyleFromPreferences();
            EnsureCachedResources();

            InitializeComponents();
            LoadTemplates();
        }

        private static void EnsureCachedResources()
        {
            _headerTitleFont ??= new Font("Microsoft YaHei UI", 13F, FontStyle.Bold);
            _headerVerFont ??= new Font("Microsoft YaHei UI", 8F);
            _headerTitleBrush ??= new SolidBrush(Theme.TextBright);
            _headerVerBrush ??= new SolidBrush(Theme.TextDim);
            _tabFontNormal ??= new Font("Microsoft YaHei UI", 9F, FontStyle.Regular);
            _tabFontBold ??= new Font("Microsoft YaHei UI", 9F, FontStyle.Bold);
            _tabSelectedBrush ??= new SolidBrush(Theme.Card);
            _tabNormalBrush ??= new SolidBrush(Theme.Bg);
            _tabTextSelectedBrush ??= new SolidBrush(Theme.TextBright);
            _tabTextNormalBrush ??= new SolidBrush(Theme.TextDim);
            _tabStringFormat ??= new StringFormat { Alignment = StringAlignment.Center, LineAlignment = StringAlignment.Center };
        }

        private CatalogStyle LoadStyleFromPreferences()
        {
            return new CatalogStyle
            {
                RowHeight = _preferences.TableRowHeight,
                MergeStrategy = MergeStrategy.PrefixConsecutive,
                SequenceFormat = SequenceFormat.Numeric,
                HeaderVisible = true,
                Columns = new List<ColumnDef>
                {
                    new ColumnDef { Tag = "XH", Header = "序号", Width = 20, Visible = true, Order = 0 },
                    new ColumnDef { Tag = "TH", Header = "图号", Width = 40, Visible = true, Order = 1 },
                    new ColumnDef { Tag = "TM", Header = "图名", Width = 60, Visible = true, Order = 2 }
                }
            };
        }

        private void InitializeComponents()
        {
            BackColor = Theme.Bg;
            ForeColor = Theme.Text;
            AutoScroll = false;
            Padding = new Padding(0);

            var root = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                RowCount = 3,
                ColumnCount = 1,
                BackColor = Theme.Bg,
                Padding = new Padding(0)
            };
            root.RowStyles.Add(new RowStyle(SizeType.Absolute, 56));
            root.RowStyles.Add(new RowStyle(SizeType.Percent, 100));
            root.RowStyles.Add(new RowStyle(SizeType.Absolute, 180));

            // Header
            var pnlHeader = new Panel { Dock = DockStyle.Fill, BackColor = Theme.Card };
            pnlHeader.Paint += (s, e) =>
            {
                var g = e.Graphics;
                g.DrawString("目录生成", _headerTitleFont, _headerTitleBrush, 12, 14);
                g.DrawString("V2.0", _headerVerFont, _headerVerBrush, 12, 34);
            };
            root.Controls.Add(pnlHeader, 0, 0);

            // TabControl with 3 tabs
            tabControl = new TabControl
            {
                Dock = DockStyle.Fill,
                BackColor = Theme.Bg,
                ForeColor = Theme.Text,
                Margin = new Padding(0),
                Padding = new Point(0, 0)
            };
            tabControl.DrawMode = TabDrawMode.OwnerDrawFixed;
            tabControl.DrawItem += TabControl_DrawItem;
            tabControl.SelectedIndexChanged += TabControl_SelectedIndexChanged;

            var tabExtract = new TabPage("提取") { BackColor = Theme.Bg, Padding = new Padding(8) };
            var tabStyle = new TabPage("样式") { BackColor = Theme.Bg, Padding = new Padding(8) };
            var tabGenerate = new TabPage("生成") { BackColor = Theme.Bg, Padding = new Padding(8) };

            tabExtract.Controls.Add(CreateExtractContent());
            tabStyle.Controls.Add(CreateStyleContent());
            tabGenerate.Controls.Add(CreateGenerateContent());

            tabControl.TabPages.Add(tabExtract);
            tabControl.TabPages.Add(tabStyle);
            tabControl.TabPages.Add(tabGenerate);
            root.Controls.Add(tabControl, 0, 1);

            // Log panel
            var logPanel = new Panel { Dock = DockStyle.Fill, BackColor = Theme.Card };
            var logHeader = new Panel { Dock = DockStyle.Top, Height = 26, BackColor = Theme.Card };
            logHeader.Controls.Add(new Label
            {
                Text = "操作日志",
                Dock = DockStyle.Left,
                AutoSize = true,
                Font = new Font("Microsoft YaHei UI", 8.5F, FontStyle.Bold),
                ForeColor = Theme.TextDim,
                Padding = new Padding(8, 4, 0, 0)
            });
            var btnClear = new Button
            {
                Text = "清空",
                Dock = DockStyle.Right,
                Width = 50,
                BackColor = Theme.Card,
                ForeColor = Theme.TextDim,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Microsoft YaHei UI", 7.5F),
                Cursor = Cursors.Hand
            };
            btnClear.FlatAppearance.BorderSize = 0;
            btnClear.Click += (s, e) => rtbLog?.Clear();
            logHeader.Controls.Add(btnClear);
            logPanel.Controls.Add(logHeader);

            rtbLog = new RichTextBox
            {
                Dock = DockStyle.Fill,
                BackColor = Theme.LogBg,
                ForeColor = Theme.Text,
                Font = new Font("Consolas", 8F),
                ReadOnly = true,
                BorderStyle = BorderStyle.None,
                WordWrap = true,
                ScrollBars = RichTextBoxScrollBars.Vertical
            };
            logPanel.Controls.Add(rtbLog);
            root.Controls.Add(logPanel, 0, 2);

            Controls.Add(root);
            AppendLog("准备就绪", Theme.TextDim);
        }

        private void TabControl_DrawItem(object sender, DrawItemEventArgs e)
        {
            var tc = sender as TabControl;
            if (tc == null) return;

            var g = e.Graphics;
            var rect = tc.GetTabRect(e.Index);

            var bgBrush = e.Index == tc.SelectedIndex ? _tabSelectedBrush : _tabNormalBrush;
            g.FillRectangle(bgBrush, rect);

            var page = tc.TabPages[e.Index];
            var font = e.Index == tc.SelectedIndex ? _tabFontBold : _tabFontNormal;
            var textBrush = e.Index == tc.SelectedIndex ? _tabTextSelectedBrush : _tabTextNormalBrush;
            g.DrawString(page.Text, font, textBrush, rect, _tabStringFormat);
        }

