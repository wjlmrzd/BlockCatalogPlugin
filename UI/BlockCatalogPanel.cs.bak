        private void UpdateColumnOrderUI()
        {
            pnlColumnOrder.Controls.Clear();

            foreach (var col in _currentStyle.Columns.OrderBy(c => c.Order))
            {
                var colBtn = CreateColumnHeaderButton(col);
                pnlColumnOrder.Controls.Add(colBtn);
            }
        }

        private Button CreateColumnHeaderButton(ColumnDef col)
        {
            var btn = new Button
            {
                Text = col.Header ?? col.Tag,
                Tag = col.Tag,
                Width = 70,
                Height = 26,
                BackColor = Theme.Card,
                ForeColor = col.Visible ? Theme.Text : Theme.TextDim,
                FlatStyle = FlatStyle.Flat,
                Margin = new Padding(2),
                Cursor = Cursors.SizeAll
            };

            // Click to toggle visibility
            btn.Click += (s, e) =>
            {
                var column = _currentStyle.Columns.FirstOrDefault(c => c.Tag == col.Tag);
                if (column != null)
                {
                    column.Visible = !column.Visible;
                    btn.ForeColor = column.Visible ? Theme.Text : Theme.TextDim;
                }
            };

            // Drag-drop support
            btn.MouseDown += ColumnBtn_MouseDown;
            btn.MouseMove += ColumnBtn_MouseMove;
            btn.MouseUp += ColumnBtn_MouseUp;

            return btn;
        }

        private void ColumnBtn_MouseDown(object sender, MouseEventArgs e)
        {
            if (e.Button == MouseButtons.Left)
            {
                var btn = sender as Button;
                if (btn != null)
                {
                    _dragColumnIndex = pnlColumnOrder.Controls.IndexOf(btn);
                    _dragStartPoint = e.Location;
                    _isDragging = false;
                }
            }
        }

        private void ColumnBtn_MouseMove(object sender, MouseEventArgs e)
        {
            if (e.Button == MouseButtons.Left && _dragColumnIndex >= 0)
            {
                var btn = sender as Button;
                if (btn != null && !_isDragging)
                {
                    // Start drag if moved enough
                    var diff = Math.Abs(e.X - _dragStartPoint.X) + Math.Abs(e.Y - _dragStartPoint.Y);
                    if (diff > 5)
                    {
                        _isDragging = true;
                        btn.DoDragDrop(btn, DragDropEffects.Move);
                    }
                }
            }
        }

        private void ColumnBtn_MouseUp(object sender, MouseEventArgs e)
        {
            _dragColumnIndex = -1;
            _isDragging = false;
        }

        private void CmbSequenceFormat_SelectedIndexChanged(object sender, EventArgs e)
        {
            _currentStyle.SequenceFormat = cmbSequenceFormat.SelectedIndex switch
            {
                0 => SequenceFormat.Numeric,
                1 => SequenceFormat.Numeric2Digit,
                2 => SequenceFormat.Circle,
                3 => SequenceFormat.Chinese,
                4 => SequenceFormat.Alpha,
                _ => SequenceFormat.Numeric
            };
        }

        private void ChkSmartMerge_CheckedChanged(object sender, EventArgs e)
        {
            _currentStyle.MergeStrategy = chkSmartMerge.Checked
                ? MergeStrategy.PrefixConsecutive
                : MergeStrategy.None;
        }

        private void ChkShowHeader_CheckedChanged(object sender, EventArgs e)
        {
            _currentStyle.HeaderVisible = chkShowHeader.Checked;
        }

        private void NumRowHeight_ValueChanged(object sender, EventArgs e)
        {
            _currentStyle.RowHeight = (double)numRowHeight.Value;
        }

        private void CmbTemplate_SelectedIndexChanged(object sender, EventArgs e)
        {
            // Template selection changed
        }

        private void BtnSaveTemplate_Click(object sender, EventArgs e)
        {
            string templateName = $"模板_{DateTime.Now:yyyyMMdd_HHmmss}";
            if (TemplateManager.Instance.Save(templateName, _currentStyle))
            {
                AppendLog($"已保存模板: {templateName}", Theme.Success);
                LoadTemplates();
            }
            else
            {
                AppendLog("模板保存失败", Theme.Error);
            }
        }

        private void BtnLoadTemplate_Click(object sender, EventArgs e)
        {
            if (cmbTemplate.SelectedItem == null) return;

            var style = TemplateManager.Instance.Load(cmbTemplate.SelectedItem.ToString());
            if (style != null)
            {
                _currentStyle = style;
                UpdateColumnOrderUI();
                numRowHeight.Value = (decimal)_currentStyle.RowHeight;
                chkSmartMerge.Checked = _currentStyle.MergeStrategy == MergeStrategy.PrefixConsecutive;
                chkShowHeader.Checked = _currentStyle.HeaderVisible;
                AppendLog($"已加载模板: {cmbTemplate.SelectedItem}", Theme.Success);
            }
            else
            {
                AppendLog("模板加载失败", Theme.Error);
            }
        }

        private void LoadTemplates()
        {
            cmbTemplate.Items.Clear();
            var templates = TemplateManager.Instance.List();
            foreach (var t in templates)
            {
                cmbTemplate.Items.Add(t);
            }
            if (cmbTemplate.Items.Count > 0)
                cmbTemplate.SelectedIndex = 0;
        }

        #endregion

        #region Tab 3 - Generate

        private Panel CreateGenerateContent()
        {
            var panel = new Panel { Dock = DockStyle.Fill, BackColor = Theme.Bg, AutoScroll = true };

            int y = 10;
            int leftMargin = 10;

            // === Output Target Section ===
            var lblOutputTarget = new Label
            {
                Text = "输出目标：",
                Location = new Point(leftMargin, y),
                AutoSize = true,
                ForeColor = Theme.TextBright,
                Font = new Font("Microsoft YaHei UI", 9F, FontStyle.Bold)
            };
            panel.Controls.Add(lblOutputTarget);
            y += 25;

            // 使用 GroupBox 包裹 RadioButtons 避免布局溢出
            var grpOutputTarget = new GroupBox
            {
                Text = "输出位置",
                Location = new Point(leftMargin, y),
                Size = new Size(panel.Width - 20, 80),
                BackColor = Theme.Bg,
                ForeColor = Theme.Text,
                FlatStyle = FlatStyle.Flat
            };

            radModelSpace = new RadioButton
            {
                Text = "模型空间",
                Location = new Point(15, 22),
                AutoSize = true,
                ForeColor = Theme.Text,
                BackColor = Theme.Bg,
                Checked = !_preferences.LastOutputToLayout
            };
            radModelSpace.CheckedChanged += (s, e) => UpdateLayoutComboState();
            grpOutputTarget.Controls.Add(radModelSpace);

            radLayout = new RadioButton
            {
                Text = "当前布局",
                Location = new Point(15, 48),
                AutoSize = true,
                ForeColor = Theme.Text,
                BackColor = Theme.Bg,
                Checked = _preferences.LastOutputToLayout
            };
            grpOutputTarget.Controls.Add(radLayout);

            cmbLayoutName = new ComboBox
            {
                Location = new Point(95, 45),
                Width = 150,
                DropDownStyle = ComboBoxStyle.DropDownList,
                BackColor = Theme.InputBg,
                ForeColor = Theme.Text,
                FlatStyle = FlatStyle.Flat,
                Enabled = radLayout.Checked
            };
            LoadLayoutNames();
            grpOutputTarget.Controls.Add(cmbLayoutName);

            panel.Controls.Add(grpOutputTarget);
            y += 90;

            // === Action Buttons ===
            var btnPreview = CreateFlatButton("预览", leftMargin, y, 80, Theme.Primary);
            btnPreview.Click += (s, e) => ShowPreview();

            var btnGenerate = CreateFlatButton("生成到位置", leftMargin + 90, y, 100, Theme.Success);
            btnGenerate.Click += (s, e) => GenerateToPosition();
            y += 40;

            // === Current Config Preview ===
            var lblConfigPreview = new Label
            {
                Text = "当前配置预览：",
                Location = new Point(leftMargin, y),
                AutoSize = true,
                ForeColor = Theme.TextBright,
                Font = new Font("Microsoft YaHei UI", 9F, FontStyle.Bold)
            };
            panel.Controls.Add(lblConfigPreview);
            y += 25;

            var pnlPreview = new Panel
            {
                Location = new Point(leftMargin, y),
                Size = new Size(panel.Width - 20, 120),
                BackColor = Theme.Card,
                BorderStyle = BorderStyle.FixedSingle,
                AutoScroll = true
            };

            var lblPreviewContent = new Label
            {
                Dock = DockStyle.Fill,
                AutoSize = false,
                Font = new Font("Consolas", 8F),
                ForeColor = Theme.Text,
                Text = "序号 | 图号 | 图名 | 层名\n" +
                       "─────┼──────┼──────┼──────\n" +
                       "  1  | 建施-1 | 平面图 | L01\n" +
                       "  2  | 建施-2 | 立面图 | L01\n" +
                       "... | ...    | ...    | ..."
            };
            pnlPreview.Controls.Add(lblPreviewContent);
            panel.Controls.Add(pnlPreview);
            y += 125;

            // Merge info
            chkMergeInGenerate = new CheckBox
            {
                Text = "合并: 建施-1~5 (5个连续块)",
                Location = new Point(leftMargin, y),
                AutoSize = true,
                ForeColor = Theme.TextDim,
                BackColor = Theme.Bg
            };
            panel.Controls.Add(chkMergeInGenerate);
            y += 30;

            return panel;
        }

        private void UpdateLayoutComboState()
        {
            cmbLayoutName.Enabled = radLayout.Checked;
            if (radLayout.Checked)
            {
                LoadLayoutNames();
            }
        }

        private void LoadLayoutNames()
        {
            cmbLayoutName.Items.Clear();
            cmbLayoutName.Items.Add("Model");
            cmbLayoutName.SelectedIndex = 0;
        }

        private void ShowPreview()
        {
            if (_currentResult == null || _currentResult.Blocks.Count == 0)
            {
                AppendLog("请先提取属性块", Theme.Warning);
                return;
            }

            AppendLog("打开预览窗口...", Theme.TextDim);
            using (var dlg = new CatalogPreviewDialog(_currentResult.Blocks, _currentStyle, null, null))
            {
                if (dlg.ShowDialog() == DialogResult.OK)
                {
                    _currentStyle = dlg.ResultStyle;
                    AppendLog("预览配置已应用", Theme.Success);
                }
            }
        }

        private void GenerateToPosition()
        {
            if (_currentResult == null || _currentResult.Blocks.Count == 0)
            {
                AppendLog("请先提取属性块", Theme.Warning);
                return;
            }

            // Save output preference
            _preferences.LastOutputToLayout = radLayout.Checked;
            PreferencesManager.Instance.Save();

            AppendLog("请在CAD中指定目录插入位置...", Theme.Primary);
            var doc = Autodesk.AutoCAD.ApplicationServices.Application.DocumentManager.MdiActiveDocument;
            if (doc != null)
            {
                Plugin._pendingGenerateAfterPick = true;
                doc.SendStringToExecute("_BCPICKPOS ", true, false, true);
            }
        }

        #endregion

        #region Event Handlers

        /// <summary>
        /// Callback when blocks are selected via CAD command
        /// </summary>
        public void OnBlocksSelected(ExtractionResult result)
        {
            _currentResult = result;
            _selectedBlockNames = result.Blocks.Select(b => b.BlockName).Distinct().ToList();
            _selectedTags = result.AllTags.ToList();

            UpdateBlockNameList();
            UpdateAttributeTagList();
            UpdateBlockFilterList();
            UpdateSelectedCount();

            AppendLog($"已提取 {result.Blocks.Count} 个块", Theme.Success);

            // Auto-switch to Style tab
            if (tabControl.SelectedIndex != 1)
            {
                tabControl.SelectedIndex = 1;
            }
        }

        private void UpdateBlockFilterList()
        {
            if (_cmbBlockFilter == null) return;
            _cmbBlockFilter.Items.Clear();
            _cmbBlockFilter.Items.Add("（全部）");
            var blockNames = _currentResult?.Blocks?.Select(b => b.BlockName).Distinct() ?? new List<string>();
            foreach (var blockName in blockNames)
            {
                _cmbBlockFilter.Items.Add(blockName);
            }
            if (_cmbBlockFilter.Items.Count > 0)
                _cmbBlockFilter.SelectedIndex = 0;
        }

        private void UpdateBlockNameList()
        {
            pnlBlockNames.Controls.Clear();
            var blockNames = _currentResult?.Blocks?.Select(b => b.BlockName).Distinct() ?? new List<string>();
            foreach (var blockName in blockNames)
            {
                var cb = new CheckBox
                {
                    Text = blockName,
                    Tag = blockName,
                    AutoSize = true,
                    ForeColor = Theme.Text,
                    BackColor = Color.Transparent,
                    Margin = new Padding(4, 2, 4, 2),
                   Checked = _selectedBlockNames.Contains(blockName)
                };
                cb.CheckedChanged += BlockName_CheckChanged;
                pnlBlockNames.Controls.Add(cb);
            }
        }

        private void BlockName_CheckChanged(object sender, EventArgs e)
        {
            var cb = sender as CheckBox;
            if (cb != null)
            {
                if (cb.Checked && !_selectedBlockNames.Contains(cb.Tag?.ToString() ?? cb.Text))
                {
                    _selectedBlockNames.Add(cb.Tag?.ToString() ?? cb.Text);
                }
                else if (!cb.Checked)
                {
                    _selectedBlockNames.Remove(cb.Tag?.ToString() ?? cb.Text);
                }
                UpdateSelectedCount();
            }
        }

        private void UpdateAttributeTagList()
        {
            pnlAttributeTags.Controls.Clear();
            foreach (var tag in _currentResult?.AllTags ?? new List<string>())
            {
                var cb = new CheckBox
                {
                    Text = tag,
                    Tag = tag,
                    AutoSize = true,
                    ForeColor = Theme.Text,
                    BackColor = Color.Transparent,
                    Margin = new Padding(4, 2, 4, 2),
                    Checked = _selectedTags.Contains(tag)
                };
                cb.CheckedChanged += AttributeTag_CheckChanged;
                pnlAttributeTags.Controls.Add(cb);
            }
        }

        private void AttributeTag_CheckChanged(object sender, EventArgs e)
        {
            var cb = sender as CheckBox;
            if (cb != null)
            {
                if (cb.Checked && !_selectedTags.Contains(cb.Tag?.ToString() ?? cb.Text))
                {
                    _selectedTags.Add(cb.Tag?.ToString() ?? cb.Text);
                }
                else if (!cb.Checked)
                {
                    _selectedTags.Remove(cb.Tag?.ToString() ?? cb.Text);
                }
            }
        }

        private void UpdateSelectedCount()
        {
            int count = _currentResult?.Blocks?.Count ?? 0;
            lblSelectedCount.Text = $"已选择: {count} 个块";
        }

        /// <summary>
        /// Insert point selected callback
        /// </summary>
        public void OnInsertPointSelected(Point3d pos)
        {
            AppendLog($"插入点已设置: ({pos.X:F1}, {pos.Y:F1})", Theme.Success);

            try
            {
                var sortedBlocks = _sortEngine.Sort(_currentResult.Blocks, SortEngine.SortType.SelectionOrder);

                string targetLayout = null;
                if (radLayout.Checked && cmbLayoutName.SelectedItem != null)
                {
                    targetLayout = cmbLayoutName.SelectedItem.ToString();
                }

                MergeConfig mergeConfig = null;
                if (chkMergeInGenerate.Checked)
                {
                    mergeConfig = new MergeConfig
                    {
                        EnableMerge = true,
                        Criterion = MergeCriterion.Prefix,
                        GroupSymbol = "-",
                        RangeSymbol = "~"
                    };
                }

                var tableId = _generator.GenerateTable(sortedBlocks, _currentStyle, mergeConfig, pos, targetLayout);
                AppendLog("目录已生成", Theme.Success);

                if (targetLayout != null)
                    AppendLog($"  插入到布局: {targetLayout}", Theme.TextDim);
            }
            catch (Exception ex)
            {
                AppendLog($"生成失败: {ex.Message}", Theme.Error);
            }
        }

        /// <summary>
        /// Block picked callback
        /// </summary>
        public void OnBlockPicked(string blockName)
        {
            AppendLog($"已选择块: {blockName}", Theme.TextDim);
            if (!string.IsNullOrEmpty(blockName) && !_selectedBlockNames.Contains(blockName))
            {
                _selectedBlockNames.Add(blockName);
                UpdateBlockNameList();
                UpdateBlockFilterList();
                UpdateSelectedCount();
            }
        }

        #endregion

        #region Helpers

        private Button CreateFlatButton(string text, int x, int y, int width, Color? bgColor = null)
        {
            var btn = new Button
            {
                Text = text,
                Location = new Point(x, y),
                Width = width,
                Height = 26,
                BackColor = bgColor ?? Theme.Card,
                ForeColor = Theme.Text,
                FlatStyle = FlatStyle.Flat,
                Cursor = Cursors.Hand,
                Font = new Font("Microsoft YaHei UI", 8F)
            };
            btn.FlatAppearance.BorderSize = 0;
            return btn;
        }

        /// <summary>
        /// Thread-safe invoke
        /// </summary>
        public void SafeInvoke(Action action)
        {
            if (InvokeRequired) Invoke(action);
            else action();
        }

        /// <summary>
        /// Append log message with timestamp
        /// </summary>
        public void AppendLog(string message, Color color)
        {
            if (rtbLog == null) return;
            if (InvokeRequired) { BeginInvoke(new Action(() => AppendLog(message, color))); return; }
            if (rtbLog.TextLength > 60000) rtbLog.Clear();
            rtbLog.SelectionStart = rtbLog.TextLength;
            rtbLog.SelectionColor = color;
            rtbLog.AppendText($"[{DateTime.Now:HH:mm:ss}] {message}\n");
            rtbLog.ScrollToCaret();
        }

        /// <summary>
        /// Get current style configuration
        /// </summary>
        public CatalogStyle GetCurrentStyle()
        {
            return _currentStyle;
        }

        /// <summary>
        /// Get current block count
        /// </summary>
        public int GetBlockCount()
        {
            return _currentResult?.Blocks?.Count ?? 0;
        }

        /// <summary>
        /// Get current block data result (for InsertPointCommand)
        /// </summary>
        public BlockDataResult GetCurrentBlockData()
        {
            if (_currentResult == null) return null;

            // Convert ExtractionResult to BlockDataResult
            var result = new BlockDataResult
            {
                AllTags = _currentResult.AllTags,
                BlockNames = _currentResult.Blocks.Select(b => b.BlockName).Distinct().ToList(),
                LayerNames = new List<string>()
            };

            // Convert AttributeBlockData to BlockData
            foreach (var attrBlock in _currentResult.Blocks)
            {
                var blockData = new BlockData
                {
                    BlockName = attrBlock.BlockName,
                    ObjectId = attrBlock.BlockId,
                    Attributes = attrBlock.Attributes?.Select(kv => new BlockAttribute { Tag = kv.Key, Value = kv.Value }).ToList()
                        ?? new List<BlockAttribute>()
                };
                result.Blocks.Add(blockData);
            }

            return result;
        }

        /// <summary>
        /// Get current merge configuration
        /// </summary>
        public MergeConfig GetCurrentMergeConfig()
        {
            return new MergeConfig
            {
                EnableMerge = _currentStyle.MergeStrategy == MergeStrategy.PrefixConsecutive,
                Criterion = MergeCriterion.Prefix,
                GroupSymbol = "-",
                RangeSymbol = "~"
            };
        }

        /// <summary>
        /// Get layout radio button state
        /// </summary>
        public bool GetLayoutRadioState()
        {
            return radLayout != null && radLayout.Checked;
        }

        /// <summary>
        /// Direct generate (for command callback)
        /// </summary>
        public void DoGenerateCatalogDirect()
        {
            if (_currentResult == null || _currentResult.Blocks.Count == 0)
            {
                AppendLog("没有可生成的块数据", Theme.Warning);
                return;
            }

            try
            {
                var sortedBlocks = _sortEngine.Sort(_currentResult.Blocks, SortEngine.SortType.SelectionOrder);

                string targetLayout = null;
                if (radLayout.Checked && cmbLayoutName.SelectedItem != null)
                {
                    targetLayout = cmbLayoutName.SelectedItem.ToString();
                }

                MergeConfig mergeConfig = null;
                if (chkMergeInGenerate.Checked || _currentStyle.MergeStrategy == MergeStrategy.PrefixConsecutive)
                {
                    mergeConfig = new MergeConfig
                    {
                        EnableMerge = true,
                        Criterion = MergeCriterion.Prefix,
                        GroupSymbol = "-",
                        RangeSymbol = "~"
                    };
                }

                var pos = Plugin._pendingInsertPoint ?? new Point3d(0, 0, 0);
                var tableId = _generator.GenerateTable(sortedBlocks, _currentStyle, mergeConfig, pos, targetLayout);
                AppendLog("目录已生成", Theme.Success);
            }
            catch (Exception ex)
            {
                AppendLog($"生成失败: {ex.Message}", Theme.Error);
            }
        }

        #endregion
    }
}