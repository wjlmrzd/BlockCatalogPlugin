        private void ExecuteCommand(string command)
        {
            var doc = Autodesk.AutoCAD.ApplicationServices.Application.DocumentManager.MdiActiveDocument;
            if (doc != null)
            {
                AppendLog($"执行命令: {command}", Theme.TextDim);
                doc.SendStringToExecute(command + " ", true, false, true);
            }
        }

        private void RefreshData()
        {
            if (_currentResult == null || _currentResult.Blocks.Count == 0)
            {
                AppendLog("没有可刷新的数据", Theme.Warning);
                return;
            }

            // Re-apply filters and update UI
            UpdateBlockNameList();
            UpdateAttributeTagList();
            ApplyFilters();
            AppendLog($"已刷新 {_currentResult.Blocks.Count} 个块数据", Theme.Success);
        }

        private void ClearSelection()
        {
            _selectedBlockNames.Clear();
            _selectedTags.Clear();
            pnlBlockNames.Controls.Clear();
            pnlAttributeTags.Controls.Clear();
            lblSelectedCount.Text = "已选择: 0 个块";
            _currentResult = null;
            AppendLog("已清除所有选择", Theme.TextDim);
        }

        private void Filter_TextChanged(object sender, EventArgs e)
        {
            ApplyFilters();
        }

        private void ApplyFilters()
        {
            // Apply regex and exclude filters to block names
            foreach (CheckBox cb in pnlBlockNames.Controls.OfType<CheckBox>())
            {
                bool visible = true;
                string blockName = cb.Tag?.ToString() ?? cb.Text;

                // Apply regex filter
                if (!string.IsNullOrEmpty(txtRegexFilter.Text))
                {
                    try
                    {
                        var regex = new System.Text.RegularExpressions.Regex(txtRegexFilter.Text,
                            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                        visible = regex.IsMatch(blockName);
                    }
                    catch
                    {
                        // Invalid regex, skip filter
                    }
                }

                // Apply exclude filter
                if (visible && !string.IsNullOrEmpty(txtExcludeFilter.Text))
                {
                    var excludes = txtExcludeFilter.Text.Split(',');
                    foreach (var ex in excludes)
                    {
                        if (blockName.Contains(ex.Trim(), StringComparison.OrdinalIgnoreCase))
                        {
                            visible = false;
                            break;
                        }
                    }
                }

                cb.Visible = visible;
            }
        }

